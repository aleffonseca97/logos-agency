# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------

# URL pública do site (local ou produção)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Supabase
# Project Settings → API no painel do Supabase
# ---------------------------------------------------------------------------

NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Chave service_role — apenas server-side; nunca exponha no client
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ---------------------------------------------------------------------------
# Resend (e-mails de contato)
# https://resend.com → API Keys
# ---------------------------------------------------------------------------

RESEND_API_KEY=re_xxxxxxxx

# E-mail que recebe os leads do formulário
CONTACT_EMAIL=logosdev.agency@gmail.com

# Remetente dos e-mails (sandbox: onboarding@resend.dev)
# Produção: verifique seu domínio no Resend
RESEND_FROM_EMAIL=LOGOS Framework <onboarding@resend.dev>

# ---------------------------------------------------------------------------
# WhatsApp
# Formato: código do país + DDD + número (somente dígitos)
# ---------------------------------------------------------------------------

# Usado no botão do client (obrigatório em produção)
NEXT_PUBLIC_WHATSAPP_NUMBER=5511999999999

# Fallback server-side (opcional se NEXT_PUBLIC_WHATSAPP_NUMBER estiver definido)
WHATSAPP_NUMBER=5511999999999
