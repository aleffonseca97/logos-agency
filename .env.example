# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------

# URL pública do site (runtime — lida pelo container em produção)
APP_URL=http://localhost:2000

# ---------------------------------------------------------------------------
# PostgreSQL
# Local: localhost:5432 | Docker no VPS: host.docker.internal:5432
# ---------------------------------------------------------------------------

DATABASE_URL=postgresql://usuario:senha@localhost:5432/logos_crm

# Produção (container Docker no VPS):
# DATABASE_URL=postgresql://usuario:senha@host.docker.internal:5432/logos_crm

# ---------------------------------------------------------------------------
# NextAuth v4
# Gerar secret: openssl rand -base64 32
# Use o MESMO valor em NEXTAUTH_SECRET e AUTH_SECRET.
# Em produção, NEXTAUTH_URL deve ser a URL pública HTTPS.
# Após rotacionar o secret, limpe cookies next-auth.session-token /
# __Secure-next-auth.session-token no browser.
# ---------------------------------------------------------------------------

NEXTAUTH_SECRET=gerar-com-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:2000

# Aliases (opcionais — o app aceita ambos)
AUTH_SECRET=gerar-com-openssl-rand-base64-32
AUTH_URL=http://localhost:2000

# Credenciais do usuário admin inicial (usado pelo seed — uma vez)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=altere-esta-senha

# ---------------------------------------------------------------------------
# Resend (e-mails de contato)
# https://resend.com → API Keys
# ---------------------------------------------------------------------------

RESEND_API_KEY=re_xxxxxxxx

# E-mail que recebe os leads do formulário
CONTACT_EMAIL=logosdev.agency@gmail.com

# Remetente dos e-mails (sandbox: onboarding@resend.dev)
# Produção: verifique seu domínio no Resend
RESEND_FROM_EMAIL=LOGOS Framework <onboarding@resend.dev>

# ---------------------------------------------------------------------------
# WhatsApp
# Formato: código do país + DDD + número (somente dígitos)
# ---------------------------------------------------------------------------

WHATSAPP_NUMBER=+393283634905

# ---------------------------------------------------------------------------
# Docker (produção no VPS)
# ---------------------------------------------------------------------------

IMAGE_NAME=ghcr.io/seu-usuario/seu-repo:latest

# =============================================================================
# GitHub Secrets (Settings → Secrets and variables → Actions)
# Todos são runtime — nenhum secret é usado no build da imagem Docker
# =============================================================================
#
# Runtime (injetadas no container via deploy):
#   APP_URL
#   NEXTAUTH_URL               (URL pública HTTPS; mesmo valor de APP_URL)
#   NEXTAUTH_SECRET           (estável entre deploys)
#   AUTH_URL                  (alias opcional de NEXTAUTH_URL)
#   AUTH_SECRET               (alias opcional de NEXTAUTH_SECRET)
#   DATABASE_URL                (use host.docker.internal no VPS)
#   WHATSAPP_NUMBER
#   RESEND_API_KEY
#   CONTACT_EMAIL
#   RESEND_FROM_EMAIL
#
# Setup de banco (workflow manual "Setup Database", uma vez, via SSH no VPS):
#   DATABASE_URL
#   ADMIN_EMAIL
#   ADMIN_PASSWORD
#
# Deploy no VPS:
#   VPS_HOST
#   VPS_USER
#   VPS_SSH_KEY
#   VPS_PORT                    (opcional, padrão 22)
#   VPS_APP_DIR                 (opcional, padrão /opt/logos-agency)
#   GHCR_TOKEN                  (PAT read:packages — pull da imagem privada)
#
# =============================================================================
